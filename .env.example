# Local-dev environment variables. In production these are injected by Cloud Run
# (the secrets come from Secret Manager via --set-secrets). Never commit real values.

# Password for Mastery Mode (guest mode needs none)
APP_PASSWORD=change-me

# Random string used to sign session cookies (generate a long random value)
SESSION_SECRET=change-me-to-a-long-random-string

# Google Generative Language API key (Gemini). ROTATE the old leaked key!
GEMINI_API_KEY=your-new-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Only needed for LOCAL runs against Firestore; on Cloud Run this is automatic.
# GOOGLE_CLOUD_PROJECT=your-project-id
