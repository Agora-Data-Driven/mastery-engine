# Local-dev environment variables. In production these are injected by Cloud Run
# (the secrets come from Secret Manager via --set-secrets). Never commit real values.

# Password for Mastery Mode (guest mode needs none)
APP_PASSWORD=change-me

# Random string used to sign session cookies (generate a long random value)
SESSION_SECRET=change-me-to-a-long-random-string

# Gemini runs through Vertex AI (billed to this GCP project's Vertex line), so
# there is NO API key. Auth is Application Default Credentials: the Cloud Run
# service account in prod, or `gcloud auth application-default login` locally.
GEMINI_MODEL=gemini-2.5-flash
# Vertex region. "global" serves the 2.5 models everywhere; set a region only if
# data residency requires it (e.g. us-central1).
GEMINI_LOCATION=global

# Kimi (optional AI engine, from https://platform.kimi.ai). Once set, "Kimi"
# appears in the model picker alongside Gemini. In production this is wired to
# Secret Manager like the other keys — never commit a real key.
# KIMI_API_KEY=
# KIMI_MODEL=kimi-k2.6
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# The GCP project for Firestore AND Vertex AI. On Cloud Run this is detected from
# the metadata server; set it for LOCAL runs.
# GOOGLE_CLOUD_PROJECT=your-project-id
